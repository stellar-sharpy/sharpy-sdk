{
  "name": "@stellar-sharpy/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Sharpy advanced split payment contract on Stellar Soroban",
  "license": "MIT",
  "author": "Sharpy Contributors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run test/client.test.ts",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ledgerhq/hw-app-str": "^6.29.0",
    "@ledgerhq/hw-transport-webhid": "^6.35.2",
    "@stellar/freighter-api": "^3.1.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "@walletconnect/sign-client": "^2.23.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "graphql": "^16.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
